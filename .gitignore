# FlashbackVHS
# Global .gitignore
#
# Ignores:
# - Operating system files
# - IDE/editor settings
# - Python & Node build artifacts
# - Secrets
# - Generated media
# - Temporary render/cache files
# ――――――――――――――――――――――――――――――――――――――――――――――――――――――――――――


