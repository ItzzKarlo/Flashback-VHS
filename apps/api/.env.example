APP_NAME=FlashbackVHS API
APP_ENV=production
APP_DEBUG=false

FRONTEND_URL=https://flashback-vhs.karlo-cavlovic.dev
CORS_ORIGINS=https://flashback-vhs.karlo-cavlovic.dev,https://tools.karlo-cavlovic.dev

STORAGE_ROOT=/data/storage
UPLOAD_DIR=/data/storage/uploads
RENDER_DIR=/data/storage/renders
PREVIEW_DIR=/data/storage/previews
TEMP_DIR=/data/storage/temp
USER_DIR=/data/storage/users
ARTWORK_DIR=/data/storage/artworks

FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
FFMPEG_FONT_FILE=/usr/share/fonts/truetype/dejavu/DejaVuSansMono.ttf

MAX_UPLOAD_MB=1024

DATABASE_URL=postgresql+psycopg://flashbackvhs:change-me@postgres:5432/flashbackvhs
ADMIN_SETUP_KEY=change-this-to-something-secret
CLEANUP_MAX_AGE_HOURS=24

ENABLE_GPU=false
GPU_ENCODER=h264_nvenc
