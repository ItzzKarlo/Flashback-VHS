APP_NAME=FlashbackVHS
APP_ENV=development
APP_DEBUG=true

FRONTEND_URL=http://localhost:3000
API_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:3000

STORAGE_ROOT=../../storage
UPLOAD_DIR=../../storage/uploads
RENDER_DIR=../../storage/renders
PREVIEW_DIR=../../storage/previews
TEMP_DIR=../../storage/temp

MAX_UPLOAD_MB=1024
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp,image/gif
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/webm,video/x-matroska

FFMPEG_PATH=../../tools/ffmpeg/ffmpeg.exe
FFPROBE_PATH=../../tools/ffmpeg/ffprobe.exe
FFMPEG_FONT_FILE=C:/Windows/Fonts/consola.ttf
ENABLE_GPU=false
GPU_ENCODER=h264_nvenc

DEFAULT_OUTPUT_FORMAT=mp4
DEFAULT_VIDEO_CODEC=libx264
DEFAULT_AUDIO_CODEC=aac
DEFAULT_IMAGE_FORMAT=jpg
DEFAULT_RESOLUTION=1080x1080
DEFAULT_CRF=20
DEFAULT_PRESET=medium

JWT_SECRET_KEY=change-this-in-real-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

DATABASE_URL=sqlite:///./flashbackvhs.db
